# Copy this to .env.local and fill in your values

# Site URL
NEXT_PUBLIC_SITE_URL=https://www.perfmonk.in

# Resend — email delivery (required for contact form emails)
# Get your key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Supabase — stores contact form submissions (server-side only)
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...   # Service role key — NEVER expose in browser

# ── Supabase table setup ─────────────────────────────────────────────────────
# Run this SQL in your Supabase SQL Editor:
#
# create table contact_submissions (
#   id uuid primary key default gen_random_uuid(),
#   name text not null,
#   email text not null,
#   company text,
#   message text not null,
#   is_demo boolean default false,
#   created_at timestamptz default now()
# );
#
# -- Enable Row Level Security (no public reads)
# alter table contact_submissions enable row level security;
# ─────────────────────────────────────────────────────────────────────────────
